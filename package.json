{
  "name": "loop-pilot",
  "version": "1.10.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && vitest run",
    "check:action-refs": "node --import tsx scripts/check-action-refs.ts",
    "init": "node --import tsx src/main-init.ts",
    "pre-fix": "node --import tsx src/main-pre-fix.ts",
    "post-fix": "node --import tsx src/main-post-fix.ts",
    "bundle:init": "esbuild dist/main-init.js --bundle --platform=node --target=node24 --format=cjs --outfile=dist/init/index.cjs --sourcemap",
    "bundle:pre-fix": "esbuild dist/main-pre-fix.js --bundle --platform=node --target=node24 --format=cjs --outfile=dist/pre-fix/index.cjs --sourcemap",
    "bundle:post-fix": "esbuild dist/main-post-fix.js --bundle --platform=node --target=node24 --format=cjs --outfile=dist/post-fix/index.cjs --sourcemap",
    "bundle": "npm run build && npm run bundle:init && npm run bundle:pre-fix && npm run bundle:post-fix"
  },
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
