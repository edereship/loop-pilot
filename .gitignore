node_modules/
.worktrees/
# Ignore everything under dist/, but re-include the subdirectories that ship as
# GitHub Actions JS action bundles. Each subdirectory needs its own re-include
# pattern (parent-directory excludes block child negations otherwise).
dist/*
!dist/init/
!dist/pre-fix/
!dist/post-fix/
# CLI bundle (TY-346). Build artifact regenerated by `npm run bundle:cli`. The
# canonical gh-looppilot repo commits its own built cli.cjs (ADR-0001); during
# staging in this repo it is generated on demand (e.g. before `gh extension
# install ./cli`).
cli/cli.cjs
